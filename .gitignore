# Ignore everything by default
/*

# Allow-list only static site sources
!/.gitignore
!/README.md
!/public/
!/public/**

# Optionally allow a license file
!/LICENSE
!/package.json
!/package-lock.json
!/scripts/
!/scripts/**
!/wrangler.toml
!/dist/
!/dist/**

# Never commit local env files (in case they exist)
.env
.env.*

# macOS junk
/.DS_Store
